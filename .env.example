# Django Configuration
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings.development

# Allowed Hosts (separados por comas)
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration (para producción con PostgreSQL)
DB_NAME=taller_db
DB_USER=taller_user
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=noreply@taller.com

# Configuración del Taller
NOMBRE_TALLER=Mi Taller de Vehículos
DIRECCION_TALLER=Calle Principal 123
TELEFONO_TALLER=+34 123 456 789
EMAIL_TALLER=info@taller.com
CIF_TALLER=B12345678

# Sentry (Monitoring en producción)
SENTRY_DSN=your-sentry-dsn-here

# Redis (Caché en producción)
REDIS_URL=redis://localhost:6379/0
