# =============================================================
# TallerVehiculos - Variables de Entorno para Producción
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el .env real al repositorio.
# =============================================================

# --- Django ---
SECRET_KEY=0021efbb-7053-42c6-867e-c3145053bdae
DEBUG=False
DJANGO_SETTINGS_MODULE=config.settings.production

# Hosts permitidos separados por coma (sin espacios)
ALLOWED_HOSTS=taller.midominio.com

# Orígenes de confianza para CSRF — debe incluir el dominio exacto con protocolo
CSRF_TRUSTED_ORIGINS=https://taller.midominio.com

# --- Base de Datos PostgreSQL ---
# En Coolify: añade un servicio PostgreSQL y vincula estas variables
DB_NAME=taller_vehiculos
DB_USER=taller_user
DB_PASSWORD=0021efbb-7053-42c6-867e-c3145053bdae
DB_HOST=localhost
DB_PORT=5432

# --- Servidor ---
PORT=8000
GUNICORN_WORKERS=3

# --- Configuración del Taller ---
NOMBRE_TALLER=Mi Taller de Vehículos
DIRECCION_TALLER=Calle Principal 123
TELEFONO_TALLER=+34 123 456 789
EMAIL_TALLER=info@taller.com
CIF_TALLER=B12345678

